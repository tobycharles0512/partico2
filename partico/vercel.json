  "outputDirectory": "backend",
  "devCommand": "cd backend && npm run dev",
  "env": {
    "RESEND_API_KEY": "@resend_api_key",
    "JWT_SECRET": "@jwt_secret"
  },
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs18.x"
    }
  }
}
